#include <bits/stdc++.h>
using namespace std;

int main() {
    string a;
    getline(cin, a);

    unordered_map<int,int> al;
    al[0] = -1; // val,index

    int csum = 0, maxl = 0;
    for (int i = 0; i < (int)a.size(); i++) {
        if (a[i] == '1') {
            csum += 1;
        } else {
            csum -= 1;
        }

        if (al.find(csum) != al.end()) {
            maxl = max(maxl, i - al[csum]);
        } else {
            al[csum] = i;
        }
    }

    cout << maxl << endl;
    return 0;
}
